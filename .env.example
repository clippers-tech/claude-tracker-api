# ============================================================
# Claude Viral Tweet Tracker — Environment Variables
# ============================================================

# REQUIRED: Your Apify API token
# Sign up at https://apify.com → Settings → Integrations → API tokens
APIFY_API_TOKEN=your_token_here

# OPTIONAL: Hour (UTC) for daily collection. Default: 9 (9am UTC)
CRON_HOUR=9
CRON_MINUTE=0

# OPTIONAL: Directory to store data files. Default: ./data
DATA_DIR=./data

# OPTIONAL: Secret to protect the manual /api/collect endpoint
COLLECT_SECRET=

# OPTIONAL: Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
